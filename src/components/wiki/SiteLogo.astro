---
interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<div class:list={["site-logo", compact && "site-logo--compact"]}>
  <svg
    class="site-logo__mark"
    viewBox="0 0 64 64"
    aria-hidden="true"
    focusable="false"
  >
    <defs>
      <linearGradient id="asterionGradient" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="currentColor" stop-opacity="1" />
        <stop offset="100%" stop-color="currentColor" stop-opacity="0.6" />
      </linearGradient>
    </defs>

    <rect
      x="6"
      y="6"
      width="52"
      height="52"
      rx="12"
      fill="none"
      stroke="url(#asterionGradient)"
      stroke-width="3"
    />

    <path
      d="M20 44L32 16L44 44"
      fill="none"
      stroke="currentColor"
      stroke-width="3.2"
      stroke-linecap="round"
      stroke-linejoin="round"
    />

    <path
      d="M24 35H40"
      fill="none"
      stroke="currentColor"
      stroke-width="3.2"
      stroke-linecap="round"
    />

    <circle cx="48" cy="16" r="3.2" fill="currentColor" />
  </svg>

  <span class="site-logo__text">
    <span class="site-logo__name">Asterion Lexicon</span>
    <span class="site-logo__tagline">Archivo privado de conocimiento</span>
  </span>
</div>