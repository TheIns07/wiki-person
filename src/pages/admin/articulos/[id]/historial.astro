---
import RevisionHistory from "../../../../components/admin/history/RevisionHistory";
import AdminLayout from "../../../../layouts/AdminLayout.astro";

import {
  createSupabaseServerClient,
} from "../../../../lib/supabase/server";

import type {
  ArticleRevision,
  ArticleStatus,
  QuickFacts,
  TocItem,
  TocLevel,
} from "../../../../types/wiki";

export const prerender = false;

Astro.response.headers.set(
  "Cache-Control",
  "private, no-store, max-age=0",
);

type ArticleRow = {
  id: string;
  title: string;
};

type RevisionRow = {
  id: string;
  article_id: string;
  revision_number: number;

  title: string;
  subtitle: string | null;
  slug: string;
  summary: string;
  status: string;
  language_code: string;

  lead_html: string;
  content_html: string;
  quick_facts: unknown;

  is_featured: boolean;
  featured_order: number | null;

  published_at: string | null;
  archived_at: string | null;

  changed_by: string | null;
  created_at: string;
};

const defaultQuickFacts: QuickFacts = {
  enabled: false,
  title: "Datos rápidos",
  summary: "",
  defaultOpen: false,
  sections: [],
};

function mutableRedirect(
  requestUrl: string,
  path: string,
): Response {
  const targetUrl =
    new URL(
      path,
      requestUrl,
    );

  return new Response(null, {
    status: 303,
    headers: {
      Location:
        targetUrl.toString(),

      "Cache-Control":
        "private, no-store",
    },
  });
}

function isRecord(
  value: unknown,
): value is Record<string, unknown> {
  return (
    typeof value === "object" &&
    value !== null &&
    !Array.isArray(value)
  );
}

function isUuid(
  value: string,
): boolean {
  return /^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/i.test(
    value,
  );
}

function normalizeStatus(
  value: unknown,
): ArticleStatus {
  if (
    value === "published" ||
    value === "archived"
  ) {
    return value;
  }

  return "draft";
}

function normalizeQuickFacts(
  value: unknown,
): QuickFacts {
  if (!isRecord(value)) {
    return defaultQuickFacts;
  }

  return {
    enabled:
      value.enabled === true,

    title:
      typeof value.title === "string" &&
      value.title.trim()
        ? value.title
        : "Datos rápidos",

    summary:
      typeof value.summary === "string"
        ? value.summary
        : "",

    defaultOpen:
      value.defaultOpen === true,

    sections:
      Array.isArray(value.sections)
        ? (
            value.sections as
              QuickFacts["sections"]
          )
        : [],
  };
}

function normalizeSlug(
  value: string,
): string {
  return value
    .normalize("NFD")
    .replace(/\p{Diacritic}/gu, "")
    .toLowerCase()
    .trim()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");
}

function htmlToPlainText(
  value: string,
): string {
  return value
    .replace(
      /<script\b[^>]*>[\s\S]*?<\/script>/gi,
      " ",
    )
    .replace(
      /<style\b[^>]*>[\s\S]*?<\/style>/gi,
      " ",
    )
    .replace(/<[^>]+>/g, " ")
    .replace(/&nbsp;/gi, " ")
    .replace(/&amp;/gi, "&")
    .replace(/&lt;/gi, "<")
    .replace(/&gt;/gi, ">")
    .replace(/&quot;/gi, '"')
    .replace(/&#39;/gi, "'")
    .replace(/\s+/g, " ")
    .trim();
}

function extractToc(
  html: string,
): TocItem[] {
  const toc: TocItem[] = [];

  const headingPattern =
    /<h([2-4])\b([^>]*)>([\s\S]*?)<\/h\1>/gi;

  let match:
    | RegExpExecArray
    | null;

  while (
    (
      match =
        headingPattern.exec(html)
    ) !== null
  ) {
    const level =
      Number(
        match[1],
      ) as TocLevel;

    const attributes =
      match[2] ?? "";

    const label =
      htmlToPlainText(
        match[3] ?? "",
      );

    if (!label) {
      continue;
    }

    const idMatch =
      attributes.match(
        /\bid=["']([^"']+)["']/i,
      );

    const generatedId =
      normalizeSlug(label) ||
      `seccion-${toc.length + 1}`;

    toc.push({
      id:
        idMatch?.[1] ??
        generatedId,

      label,
      level,
    });
  }

  return toc;
}

function getChangeNote(
  revisionNumber: number,
): string {
  return revisionNumber === 1
    ? "Creación del artículo"
    : "Actualización del artículo";
}

function mapRevision(
  row: RevisionRow,
): ArticleRevision {
  const leadHtml =
    row.lead_html ?? "";

  const contentHtml =
    row.content_html ?? "";

  return {
    id:
      row.id,

    articleId:
      row.article_id,

    revisionNumber:
      row.revision_number,

    title:
      row.title,

    slug:
      row.slug,

    subtitle:
      row.subtitle ?? "",

    summary:
      row.summary ?? "",

    leadHtml,

    contentHtml,

    /*
     * La tabla actual no almacena
     * el JSON de Tiptap.
     */
    contentJson:
      null,

    plainText:
      htmlToPlainText(
        `${leadHtml} ${contentHtml}`,
      ),

    status:
      normalizeStatus(
        row.status,
      ),

    featured:
      row.is_featured === true,

    toc:
      extractToc(
        contentHtml,
      ),

    quickFacts:
      normalizeQuickFacts(
        row.quick_facts,
      ),

    /*
     * El esquema actual de revisiones no
     * conserva categorías, alias ni relaciones
     * históricas.
     */
    categoryIds: [],
    aliases: [],
    relatedArticleIds: [],

    publishedAt:
      row.published_at ?? null,

    changeNote:
      getChangeNote(
        row.revision_number,
      ),

    createdAt:
      row.created_at,
  };
}

function getErrorMessage(
  error: unknown,
): string {
  if (
    error instanceof Error
  ) {
    return error.message;
  }

  if (
    isRecord(error) &&
    typeof error.message === "string"
  ) {
    return error.message;
  }

  return "Ocurrió un error desconocido.";
}

const articleId =
  Astro.params.id?.trim() ?? "";

let article:
  | ArticleRow
  | null = null;

let revisions:
  ArticleRevision[] = [];

let loadError = "";

if (
  !articleId ||
  !isUuid(articleId)
) {
  Astro.response.status = 404;
} else {
  try {
    const supabase =
      createSupabaseServerClient({
        request:
          Astro.request,

        cookies:
          Astro.cookies,
      });

    const {
      data: {
        user,
      },
      error: userError,
    } =
      await supabase.auth.getUser();

    if (
      userError ||
      !user
    ) {
      return mutableRedirect(
        Astro.request.url,
        "/admin/login?error=Tu%20sesión%20expiró.%20Inicia%20sesión%20nuevamente.",
      );
    }

    const {
      data: profile,
      error: profileError,
    } = await supabase
      .from("profiles")
      .select("id, role")
      .eq("id", user.id)
      .maybeSingle();

    if (profileError) {
      throw new Error(
        `No fue posible verificar tus permisos: ${profileError.message}`,
      );
    }

    if (
      profile?.role !==
      "admin"
    ) {
      return mutableRedirect(
        Astro.request.url,
        "/admin/login?error=Tu%20cuenta%20no%20tiene%20permisos%20de%20administrador.",
      );
    }

    const {
      data: articleData,
      error: articleError,
    } = await supabase
      .from("articles")
      .select(
        "id, title",
      )
      .eq(
        "id",
        articleId,
      )
      .maybeSingle();

    if (articleError) {
      throw new Error(
        `No fue posible cargar el artículo: ${articleError.message}`,
      );
    }

    if (!articleData) {
      Astro.response.status =
        404;
    } else {
      article =
        articleData as ArticleRow;

      const {
        data: revisionData,
        error: revisionError,
      } = await supabase
        .from(
          "article_revisions",
        )
        .select(`
          id,
          article_id,
          revision_number,
          title,
          subtitle,
          slug,
          summary,
          status,
          language_code,
          lead_html,
          content_html,
          quick_facts,
          is_featured,
          featured_order,
          published_at,
          archived_at,
          changed_by,
          created_at
        `)
        .eq(
          "article_id",
          articleId,
        )
        .order(
          "revision_number",
          {
            ascending: false,
          },
        );

      if (revisionError) {
        throw new Error(
          `No fue posible cargar las revisiones: ${revisionError.message}`,
        );
      }

      revisions =
        (
          revisionData ?? []
        )
          .map(
            (revision) =>
              mapRevision(
                revision as RevisionRow,
              ),
          );
    }
  } catch (error) {
    console.error(
      `[GET /admin/articulos/${articleId}/historial]`,
      error,
    );

    loadError =
      getErrorMessage(
        error,
      );

    Astro.response.status =
      500;
  }
}
---

<AdminLayout
  title={
    article
      ? `Historial de ${article.title}`
      : loadError
        ? "Error al cargar el historial"
        : "Artículo no encontrado"
  }
  description="Historial de revisiones del artículo."
>
  {
    article && !loadError ? (
      <>
        <header class="admin-page-header">
          <div>
            <h1>
              Historial de revisiones
            </h1>

            <p>
              {article.title}
              {" · "}
              {revisions.length}
              {
                revisions.length === 1
                  ? " revisión"
                  : " revisiones"
              }
            </p>
          </div>

          <div class="admin-page-header__actions">
            <a
              href={`/admin/articulos/${article.id}/vista-previa`}
              class="admin-button admin-button--secondary"
              target="_blank"
              rel="noreferrer"
            >
              Vista previa
            </a>

            <a
              href={`/admin/articulos/${article.id}`}
              class="admin-button admin-button--primary"
            >
              Volver al editor
            </a>
          </div>
        </header>

        <RevisionHistory
          client:load
          articleId={article.id}
          articleTitle={article.title}
          revisions={revisions}
        />
      </>
    ) : loadError ? (
      <section class="admin-panel admin-not-found">
        <h1>
          No fue posible cargar el historial
        </h1>

        <p>
          {loadError}
        </p>

        <a href="/admin/articulos">
          Volver a artículos
        </a>
      </section>
    ) : (
      <section class="admin-panel admin-not-found">
        <h1>
          Artículo no encontrado
        </h1>

        <p>
          No es posible mostrar el historial
          porque el artículo no existe.
        </p>

        <a href="/admin/articulos">
          Volver a artículos
        </a>
      </section>
    )
  }
</AdminLayout>