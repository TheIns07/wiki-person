---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { localWikiRepository } from "../../lib/wiki/local-wiki-repository";

const dashboard =
  await localWikiRepository.getDashboardData();

const numberFormatter =
  new Intl.NumberFormat("es-MX");

const dateFormatter =
  new Intl.DateTimeFormat("es-MX", {
    dateStyle: "medium",
  });

const statistics = [
  {
    label: "Artículos totales",
    value: dashboard.statistics.totalArticles,
    description: "Contenido registrado",
    tone: "neutral",
  },
  {
    label: "Publicados",
    value: dashboard.statistics.publishedArticles,
    description: "Visibles en el sitio",
    tone: "success",
  },
  {
    label: "Borradores",
    value: dashboard.statistics.draftArticles,
    description: "Pendientes de publicación",
    tone: "warning",
  },
  {
    label: "Archivados",
    value: dashboard.statistics.archivedArticles,
    description: "Retirados del sitio",
    tone: "muted",
  },
  {
    label: "Impresiones",
    value: dashboard.statistics.totalViews,
    description: "Consultas acumuladas",
    tone: "info",
  },
  {
    label: "Enlaces pendientes",
    value: dashboard.statistics.brokenLinkCount,
    description: "Referencias por revisar",
    tone:
      dashboard.statistics.brokenLinkCount > 0
        ? "danger"
        : "success",
  },
  {
    label: "Categorías",
    value: dashboard.statistics.totalCategories,
    description: "Grupos temáticos",
    tone: "neutral",
  },
];

const hasPopularArticles =
  dashboard.popularArticles.length > 0;

const hasRecentArticles =
  dashboard.recentlyUpdatedArticles.length > 0;
---

<AdminLayout
  title="Resumen"
  description="Resumen administrativo de Asterion Lexicon."
>
  <div class="dashboard">
    <header class="dashboard-header">
      <div class="dashboard-header__copy">
        <p class="dashboard-eyebrow">
          Panel administrativo
        </p>

        <h1>Resumen</h1>

        <p class="dashboard-description">
          Consulta el estado actual de los artículos,
          revisa la actividad reciente y administra el
          contenido de la enciclopedia.
        </p>
      </div>

      <div class="dashboard-header__actions">
        <a
          href="/admin/articulos"
          class="dashboard-button dashboard-button--secondary"
        >
          Ver artículos
        </a>

        <a
          href="/admin/articulos/nuevo"
          class="dashboard-button dashboard-button--primary"
        >
          <span aria-hidden="true">＋</span>
          Nuevo artículo
        </a>
      </div>
    </header>

    <section
      class="dashboard-stat-grid"
      aria-label="Estadísticas generales"
    >
      {
        statistics.map((statistic) => (
          <article
            class:list={[
              "dashboard-stat-card",
              `dashboard-stat-card--${statistic.tone}`,
            ]}
          >
            <div class="dashboard-stat-card__top">
              <p class="dashboard-stat-card__label">
                {statistic.label}
              </p>

              <span
                class="dashboard-stat-card__indicator"
                aria-hidden="true"
              ></span>
            </div>

            <p class="dashboard-stat-card__value">
              {numberFormatter.format(
                statistic.value,
              )}
            </p>

            <p class="dashboard-stat-card__description">
              {statistic.description}
            </p>
          </article>
        ))
      }
    </section>

    <section
      class="dashboard-content-grid"
      aria-label="Actividad del contenido"
    >
      <article class="dashboard-panel">
        <header class="dashboard-panel__header">
          <div>
            <p class="dashboard-panel__eyebrow">
              Rendimiento
            </p>

            <h2>Artículos más consultados</h2>
          </div>

          <a href="/admin/articulos">
            Ver todos
          </a>
        </header>

        {
          hasPopularArticles ? (
            <ol class="dashboard-ranking">
              {dashboard.popularArticles.map(
                (article, index) => (
                  <li>
                    <span
                      class="dashboard-ranking__number"
                      aria-hidden="true"
                    >
                      {index + 1}
                    </span>

                    <div class="dashboard-ranking__content">
                      <a
                        href={`/wiki/${article.slug}`}
                        class="dashboard-ranking__title"
                      >
                        {article.title}
                      </a>

                      <span class="dashboard-ranking__metadata">
                        {numberFormatter.format(
                          article.viewCount,
                        )}
                        {" impresiones"}
                      </span>
                    </div>
                  </li>
                ),
              )}
            </ol>
          ) : (
            <div class="dashboard-empty-state">
              <p>
                Todavía no hay artículos consultados.
              </p>
            </div>
          )
        }
      </article>

      <article class="dashboard-panel">
        <header class="dashboard-panel__header">
          <div>
            <p class="dashboard-panel__eyebrow">
              Actividad
            </p>

            <h2>Modificados recientemente</h2>
          </div>

          <a href="/admin/articulos">
            Administrar
          </a>
        </header>

        {
          hasRecentArticles ? (
            <ul class="dashboard-recent-list">
              {dashboard.recentlyUpdatedArticles.map(
                (article) => (
                  <li>
                    <div class="dashboard-recent-list__content">
                      <a
                        href={`/admin/articulos/${article.id}`}
                        class="dashboard-recent-list__title"
                      >
                        {article.title}
                      </a>

                      <span>
                        Última modificación
                      </span>
                    </div>

                    <time
                      datetime={article.updatedAt}
                    >
                      {dateFormatter.format(
                        new Date(article.updatedAt),
                      )}
                    </time>
                  </li>
                ),
              )}
            </ul>
          ) : (
            <div class="dashboard-empty-state">
              <p>
                No hay modificaciones recientes.
              </p>
            </div>
          )
        }
      </article>
    </section>

    <section class="dashboard-quick-actions">
      <div>
        <p class="dashboard-panel__eyebrow">
          Acciones rápidas
        </p>

        <h2>Continúa trabajando</h2>

        <p>
          Crea contenido nuevo, revisa borradores o
          consulta la versión pública del sitio.
        </p>
      </div>

      <nav
        class="dashboard-quick-actions__links"
        aria-label="Acciones rápidas"
      >
        <a href="/admin/articulos/nuevo">
          Crear artículo
        </a>

        <a href="/admin/articulos">
          Revisar contenido
        </a>

        <a href="/" target="_blank">
          Abrir sitio público
        </a>
      </nav>
    </section>
  </div>
</AdminLayout>

<style>
  .dashboard {
    display: grid;
    gap: 28px;
  }

  .dashboard-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    padding: 4px 0 8px;
    gap: 32px;
  }

  .dashboard-header__copy {
    max-width: 720px;
  }

  .dashboard-eyebrow,
  .dashboard-panel__eyebrow {
    margin: 0 0 5px;
    color: var(--text-subtle);
    font-family: var(--font-interface);
    font-size: 0.72rem;
    font-weight: 700;
    line-height: 1.4;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .dashboard-header h1 {
    margin: 0;
    color: var(--text-heading);
    font-family: var(--font-serif);
    font-size: clamp(2.4rem, 5vw, 3.4rem);
    font-weight: 400;
    line-height: 1.08;
    letter-spacing: -0.025em;
  }

  .dashboard-description {
    max-width: 650px;
    margin: 10px 0 0;
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.6;
  }

  .dashboard-header__actions {
    display: flex;
    flex: 0 0 auto;
    align-items: center;
    gap: 10px;
  }

  .dashboard-button {
    display: inline-flex;
    min-height: 42px;
    align-items: center;
    justify-content: center;
    padding: 8px 15px;
    gap: 6px;
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-medium);
    font-family: var(--font-interface);
    font-size: 0.875rem;
    font-weight: 700;
    line-height: 1.4;
    text-decoration: none;
    white-space: nowrap;
  }

  .dashboard-button:hover {
    text-decoration: none;
  }

  .dashboard-button--secondary {
    background: transparent;
    color: var(--text-heading);
  }

  .dashboard-button--secondary:visited {
    color: var(--text-heading);
  }

  .dashboard-button--secondary:hover {
    background: var(--surface-hover);
  }

  .dashboard-button--primary {
    border-color: var(--link);
    background: var(--link);
    color: #ffffff;
  }

  .dashboard-button--primary:visited {
    color: #ffffff;
  }

  .dashboard-button--primary:hover {
    border-color: var(--link-hover);
    background: var(--link-hover);
    color: #ffffff;
  }

  .dashboard-stat-grid {
    display: grid;
    grid-template-columns:
      repeat(4, minmax(0, 1fr));
    gap: 14px;
  }

  .dashboard-stat-card {
    position: relative;
    min-width: 0;
    padding: 19px 20px 18px;
    overflow: hidden;
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-medium);
    background: var(--background);
  }

  .dashboard-stat-card::before {
    position: absolute;
    top: 0;
    right: 0;
    left: 0;
    height: 3px;
    background: var(--stat-accent, var(--border));
    content: "";
  }

  .dashboard-stat-card--success {
    --stat-accent: #14866d;
  }

  .dashboard-stat-card--warning {
    --stat-accent: #b67a00;
  }

  .dashboard-stat-card--danger {
    --stat-accent: #b32424;
  }

  .dashboard-stat-card--info {
    --stat-accent: var(--link);
  }

  .dashboard-stat-card--muted {
    --stat-accent: var(--text-subtle);
  }

  .dashboard-stat-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .dashboard-stat-card__label {
    margin: 0;
    color: var(--text-muted);
    font-family: var(--font-interface);
    font-size: 0.8125rem;
    font-weight: 600;
    line-height: 1.4;
  }

  .dashboard-stat-card__indicator {
    width: 8px;
    height: 8px;
    flex: 0 0 auto;
    border-radius: 50%;
    background: var(--stat-accent, var(--border));
  }

  .dashboard-stat-card__value {
    margin: 15px 0 2px;
    color: var(--text-heading);
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 400;
    line-height: 1;
  }

  .dashboard-stat-card__description {
    margin: 8px 0 0;
    color: var(--text-subtle);
    font-size: 0.75rem;
    line-height: 1.4;
  }

  .dashboard-content-grid {
    display: grid;
    grid-template-columns:
      repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  .dashboard-panel {
    min-width: 0;
    padding: 23px 24px;
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-medium);
    background: var(--background);
  }

  .dashboard-panel__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 18px;
    padding-bottom: 16px;
    gap: 20px;
    border-bottom: 1px solid var(--border-subtle);
  }

  .dashboard-panel__header h2,
  .dashboard-quick-actions h2 {
    margin: 0;
    color: var(--text-heading);
    font-family: var(--font-serif);
    font-size: 1.55rem;
    font-weight: 400;
    line-height: 1.25;
  }

  .dashboard-panel__header > a {
    flex: 0 0 auto;
    font-family: var(--font-interface);
    font-size: 0.8125rem;
  }

  .dashboard-ranking,
  .dashboard-recent-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .dashboard-ranking li,
  .dashboard-recent-list li {
    display: flex;
    align-items: center;
    min-width: 0;
    padding: 13px 0;
    gap: 14px;
    border-bottom: 1px solid var(--border-subtle);
  }

  .dashboard-ranking li:last-child,
  .dashboard-recent-list li:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .dashboard-ranking li:first-child,
  .dashboard-recent-list li:first-child {
    padding-top: 0;
  }

  .dashboard-ranking__number {
    display: inline-flex;
    width: 30px;
    height: 30px;
    flex: 0 0 auto;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border-soft);
    border-radius: 50%;
    background: var(--surface);
    color: var(--text-muted);
    font-family: var(--font-interface);
    font-size: 0.75rem;
    font-weight: 700;
  }

  .dashboard-ranking__content,
  .dashboard-recent-list__content {
    display: flex;
    min-width: 0;
    flex: 1 1 auto;
    flex-direction: column;
  }

  .dashboard-ranking__title,
  .dashboard-recent-list__title {
    width: fit-content;
    max-width: 100%;
    overflow: hidden;
    font-weight: 600;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .dashboard-ranking__metadata,
  .dashboard-recent-list__content span,
  .dashboard-recent-list time {
    color: var(--text-subtle);
    font-family: var(--font-interface);
    font-size: 0.75rem;
    line-height: 1.4;
  }

  .dashboard-ranking__metadata {
    margin-top: 2px;
  }

  .dashboard-recent-list time {
    flex: 0 0 auto;
    white-space: nowrap;
  }

  .dashboard-empty-state {
    padding: 28px 18px;
    border: 1px dashed var(--border-soft);
    background: var(--surface);
    color: var(--text-muted);
    text-align: center;
  }

  .dashboard-empty-state p {
    margin: 0;
  }

  .dashboard-quick-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24px;
    gap: 28px;
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-medium);
    background: var(--surface);
  }

  .dashboard-quick-actions > div {
    max-width: 600px;
  }

  .dashboard-quick-actions p:last-child {
    margin: 7px 0 0;
    color: var(--text-muted);
    line-height: 1.55;
  }

  .dashboard-quick-actions__links {
    display: flex;
    flex: 0 0 auto;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 8px 16px;
  }

  .dashboard-quick-actions__links a {
    font-family: var(--font-interface);
    font-size: 0.8125rem;
    font-weight: 600;
  }

  @media (max-width: 1180px) {
    .dashboard-stat-grid {
      grid-template-columns:
        repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 850px) {
    .dashboard-header {
      display: block;
    }

    .dashboard-header__actions {
      margin-top: 20px;
    }

    .dashboard-content-grid {
      grid-template-columns: 1fr;
    }

    .dashboard-quick-actions {
      display: block;
    }

    .dashboard-quick-actions__links {
      justify-content: flex-start;
      margin-top: 18px;
    }
  }

  @media (max-width: 560px) {
    .dashboard {
      gap: 20px;
    }

    .dashboard-header__actions {
      display: grid;
      grid-template-columns: 1fr;
    }

    .dashboard-button {
      width: 100%;
    }

    .dashboard-stat-grid {
      grid-template-columns: 1fr;
      gap: 10px;
    }

    .dashboard-stat-card {
      padding: 17px;
    }

    .dashboard-panel {
      padding: 19px 17px;
    }

    .dashboard-panel__header {
      display: block;
    }

    .dashboard-panel__header > a {
      display: inline-block;
      margin-top: 8px;
    }

    .dashboard-recent-list li {
      align-items: flex-start;
    }

    .dashboard-recent-list time {
      max-width: 90px;
      text-align: right;
      white-space: normal;
    }

    .dashboard-quick-actions {
      padding: 20px 17px;
    }

    .dashboard-quick-actions__links {
      display: grid;
      grid-template-columns: 1fr;
    }
  }
</style>