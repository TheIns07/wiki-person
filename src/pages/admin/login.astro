---
export const prerender = false;

const errorMessage =
  Astro.url.searchParams.get("error");
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />

    <meta
      name="viewport"
      content="width=device-width"
    />

    <meta
      name="robots"
      content="noindex, nofollow"
    />

    <title>
      Acceso administrativo | Asterion Lexicon
    </title>

    <meta
      name="description"
      content="Acceso administrativo de Asterion Lexicon."
    />
  </head>

  <body>
    <main class="login-page">
      <section class="login-card">
        <a
          class="brand"
          href="/"
          aria-label="Volver a Asterion Lexicon"
        >
          <span
            class="brand-symbol"
            aria-hidden="true"
          >
            A
          </span>

          <span class="brand-text">
            <strong>
              Asterion Lexicon
            </strong>

            <small>
              Archivo privado de conocimiento
            </small>
          </span>
        </a>

        <div class="login-heading">
          <p class="eyebrow">
            Administración
          </p>

          <h1>
            Iniciar sesión
          </h1>

          <p>
            Accede con la cuenta administradora
            registrada en Supabase.
          </p>
        </div>

        {
          errorMessage && (
            <div
              class="error-message"
              role="alert"
            >
              {errorMessage}
            </div>
          )
        }

        <form
          class="login-form"
          method="POST"
          action="/api/auth/login"
        >
          <label>
            <span>
              Correo electrónico
            </span>

            <input
              type="email"
              name="email"
              autocomplete="email"
              required
              autofocus
              placeholder="correo@ejemplo.com"
            />
          </label>

          <label>
            <span>
              Contraseña
            </span>

            <input
              type="password"
              name="password"
              autocomplete="current-password"
              required
              minlength="6"
              placeholder="Tu contraseña"
            />
          </label>

          <button type="submit">
            Ingresar al administrador
          </button>
        </form>

        <a
          class="return-link"
          href="/"
        >
          ← Volver al archivo
        </a>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: light dark;
    font-family:
      Inter,
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-width: 320px;
    min-height: 100vh;
    color: #202122;
    background:
      radial-gradient(
        circle at 15% 15%,
        rgba(51, 102, 204, 0.14),
        transparent 34rem
      ),
      radial-gradient(
        circle at 85% 80%,
        rgba(114, 83, 237, 0.12),
        transparent 30rem
      ),
      #f8f9fa;
  }

  .login-page {
    display: grid;
    min-height: 100vh;
    padding: 32px 20px;
    place-items: center;
  }

  .login-card {
    width: min(100%, 440px);
    padding: 34px;
    border: 1px solid #c8ccd1;
    border-radius: 14px;
    background: rgba(
      255,
      255,
      255,
      0.94
    );
    box-shadow:
      0 22px 65px
      rgba(32, 33, 34, 0.12);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    color: inherit;
    text-decoration: none;
  }

  .brand-symbol {
    display: grid;
    width: 44px;
    height: 44px;
    border: 1px solid #3366cc;
    border-radius: 10px;
    color: #fff;
    background: #3366cc;
    font-family:
      Georgia,
      "Times New Roman",
      serif;
    font-size: 24px;
    place-items: center;
  }

  .brand-text {
    display: grid;
    gap: 2px;
  }

  .brand-text strong {
    font-family:
      Georgia,
      "Times New Roman",
      serif;
    font-size: 18px;
  }

  .brand-text small {
    color: #54595d;
    font-size: 12px;
  }

  .login-heading {
    margin-top: 34px;
    margin-bottom: 24px;
  }

  .eyebrow {
    margin: 0 0 7px;
    color: #3366cc;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-family:
      Georgia,
      "Times New Roman",
      serif;
    font-size: clamp(
      30px,
      5vw,
      38px
    );
    font-weight: 400;
  }

  .login-heading > p:last-child {
    margin:
      10px 0 0;
    color: #54595d;
    line-height: 1.6;
  }

  .error-message {
    margin-bottom: 20px;
    padding: 12px 14px;
    border: 1px solid #b32424;
    border-radius: 7px;
    color: #8b1919;
    background: #fee7e6;
    font-size: 14px;
    line-height: 1.5;
  }

  .login-form {
    display: grid;
    gap: 18px;
  }

  .login-form label {
    display: grid;
    gap: 7px;
  }

  .login-form label span {
    font-size: 14px;
    font-weight: 650;
  }

  .login-form input {
    width: 100%;
    min-height: 46px;
    padding: 10px 12px;
    border: 1px solid #a2a9b1;
    border-radius: 6px;
    color: #202122;
    background: #fff;
    font: inherit;
    outline: none;
  }

  .login-form input:focus {
    border-color: #3366cc;
    box-shadow:
      0 0 0 3px
      rgba(51, 102, 204, 0.16);
  }

  .login-form button {
    min-height: 48px;
    margin-top: 4px;
    padding: 11px 18px;
    border: 1px solid #2a4b8d;
    border-radius: 6px;
    color: #fff;
    background: #3366cc;
    font: inherit;
    font-weight: 700;
    cursor: pointer;
  }

  .login-form button:hover {
    background: #2a4b8d;
  }

  .login-form button:focus-visible {
    outline: 3px solid
      rgba(51, 102, 204, 0.3);
    outline-offset: 2px;
  }

  .return-link {
    display: inline-block;
    margin-top: 26px;
    color: #3366cc;
    font-size: 14px;
    text-decoration: none;
  }

  .return-link:hover {
    text-decoration: underline;
  }

  @media (
    prefers-color-scheme: dark
  ) {
    body {
      color: #eaecf0;
      background:
        radial-gradient(
          circle at 15% 15%,
          rgba(89, 142, 235, 0.18),
          transparent 34rem
        ),
        radial-gradient(
          circle at 85% 80%,
          rgba(145, 110, 255, 0.14),
          transparent 30rem
        ),
        #101418;
    }

    .login-card {
      border-color: #54595d;
      background:
        rgba(32, 33, 34, 0.96);
      box-shadow:
        0 24px 70px
        rgba(0, 0, 0, 0.32);
    }

    .brand-text small,
    .login-heading > p:last-child {
      color: #a2a9b1;
    }

    .login-form input {
      border-color: #72777d;
      color: #eaecf0;
      background: #202122;
    }

    .error-message {
      border-color: #d73333;
      color: #ffb4ab;
      background: rgba(
        179,
        36,
        36,
        0.18
      );
    }
  }

  @media (max-width: 520px) {
    .login-page {
      padding: 18px 12px;
    }

    .login-card {
      padding: 26px 20px;
    }
  }
</style>