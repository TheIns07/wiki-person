---
import ArticleView from "../../components/wiki/ArticleView.astro";
import WikiLayout from "../../layouts/WikiLayout.astro";

import {
  localWikiRepository,
} from "../../lib/wiki/local-wiki-repository";

export async function getStaticPaths() {
  const publishedArticles =
    await localWikiRepository.listArticles({
      status: "published",
    });

  return publishedArticles.map((article) => ({
    params: {
      slug: article.slug,
    },
  }));
}

const slug = Astro.params.slug;

const articlePageData = slug
  ? await localWikiRepository.getPublishedArticleBySlug(
      slug,
    )
  : null;

if (!articlePageData) {
  Astro.response.status = 404;
}

const currentViewCount =
  articlePageData?.article.viewCount ?? 0;
---